# Coin-specific config for the Flux HA masternode template.
# The generic scripts (node_initialize.sh, mn-autoheal.sh, check-health.sh) are
# identical across coins; only this file changes per coin.
# All values verified against Raptor3um/raptoreum source (see README).
COIN_TICKER="RTM"
COIN_DAEMON="raptoreumd"
COIN_CLI_BIN="raptoreum-cli"
DATADIR="/raptoreum/.raptoreumcore"     # default dir .raptoreumcore (util/system.cpp:733)
CONF="${DATADIR}/raptoreum.conf"        # BITCOIN_CONF_FILENAME (util/system.cpp:82)
MN_PORT=10226                           # CMainParams nDefaultPort (chainparams.cpp:243)
BLS_PARAM="smartnodeblsprivkey"         # init.cpp:877 (RTM uses smartnode naming)
SEED_NODES="explorer.raptoreum.com raptor.mopsus.com"
CLI="${COIN_CLI_BIN} -datadir=${DATADIR} -conf=${CONF}"
